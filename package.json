{
    "name": "pr-radiobutton-checkboxes",
    "version": "1.0.0",
    "description": "GitHub Action: enforce radio-button mutual exclusivity in PR description checkboxes",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc --noEmit",
        "bundle": "ncc build src/main.ts --out dist --license licenses.txt --minify",
        "bundle:dev": "ncc build src/main.ts --out dist --source-map",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "lint": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "all": "npm run build && npm test && npm run bundle",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,js,json,yml,yaml,md}": "prettier --write"
    },
    "dependencies": {
        "@actions/core": "^1.10.1",
        "@actions/github": "^6.0.0",
        "minimatch": "^9.0.5"
    },
    "devDependencies": {
        "@octokit/webhooks-types": "^7.6.1",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.14.0",
        "@vercel/ncc": "^0.38.1",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "ts-jest": "^29.1.4",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.5"
    }
}
